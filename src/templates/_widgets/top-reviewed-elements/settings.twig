{# @var widget \bymayo\vouch\widgets\TopReviewedElementsWidget #}
{# @var elementTypeOptions array #}
{# @var sectionOptions array #}
{# @var sortOptions array #}
{# @var entryClass string #}
{% import '_includes/forms' as forms %}

{{ forms.selectField({
    label: 'Element type'|t('vouch'),
    id: 'elementType',
    name: 'elementType',
    value: widget.elementType,
    options: elementTypeOptions,
    inputAttributes: {
        'data-vouch-element-type': true,
    },
}) }}

{# Section only applies to Entries. Hidden by default for any other element type;
   toggled live by the JS at the bottom. Use a data-attribute (not an id) so the
   selector survives Craft's namespaced widget-settings form IDs. #}
<div data-vouch-section-row{% if widget.elementType != entryClass %} class="hidden"{% endif %}>
    {{ forms.selectField({
        label: 'Section'|t('vouch'),
        id: 'sectionId',
        name: 'sectionId',
        value: widget.sectionId,
        options: sectionOptions,
    }) }}
</div>

{{ forms.selectField({
    label: 'Sort by'|t('vouch'),
    id: 'sort',
    name: 'sort',
    value: widget.sort,
    options: sortOptions,
}) }}

{{ forms.textField({
    label: 'Limit'|t('vouch'),
    id: 'limit',
    name: 'limit',
    value: widget.limit,
    type: 'number',
    min: 1,
    max: 50,
}) }}

{% js %}
// Delegated handler so it works regardless of when the widget settings form
// is inserted into the DOM (Craft loads the modal via AJAX) and regardless
// of the namespaced IDs Craft applies to widget settings fields.
$(document).off('change.vouchTopReviewed').on('change.vouchTopReviewed', 'select[data-vouch-element-type]', function() {
    var $row = $(this).closest('form, .body, .pane, .meta').find('[data-vouch-section-row]');
    if (!$row.length) return;
    if ($(this).val() === {{ entryClass|json_encode|raw }}) {
        $row.removeClass('hidden');
    } else {
        $row.addClass('hidden');
    }
});
{% endjs %}
