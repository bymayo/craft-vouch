{# @var rows array #}
{# @var elementsById \craft\base\ElementInterface[] #}
{# @var columnLabel string #}

{% if rows|length %}
    <div class="tableview vouch-widget-tableview vouch-pt-6">
        <div class="tablepane">
            <table class="data fullwidth vouch-widget-table">
                <thead>
                    <tr>
                        <th>{{ columnLabel }}</th>
                        <th>{{ 'Rating'|t('vouch') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        {% set element = elementsById[row.elementId] ?? null %}
                        <tr>
                            <td>
                                {% if element and element.cpEditUrl %}
                                    <a href="{{ element.cpEditUrl }}">{{ element.title ?: element.uiLabel }}</a>
                                {% elseif element %}
                                    {{ element.title ?: element.uiLabel }}
                                {% else %}
                                    <span class="light">#{{ row.elementId }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {{ row.average|number_format(1) }} ★
                                <span class="light">({{ row.count }} {{ row.count == 1 ? 'review'|t('vouch') : 'reviews'|t('vouch') }})</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="vouch-widget-footer vouch-mt-5 -vouch-mx-6 vouch-mb-0 vouch-pt-5 vouch-px-6 vouch-pb-0 vouch-border-t vouch-border-[color:var(--hairline-color)]">
        <a class="btn small" href="{{ cpUrl('vouch/reviews') }}">{{ 'View all reviews'|t('vouch') }}</a>
    </div>
{% else %}
    <p>{{ 'No reviewed elements yet.'|t('vouch') }}</p>
{% endif %}
