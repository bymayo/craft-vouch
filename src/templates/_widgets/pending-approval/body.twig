{# @var reviews \bymayo\vouch\elements\Review[] #}
{# @var indexUrl string #}

{% if reviews|length %}
    <div class="tableview vouch-widget-tableview vouch-pt-6">
        <div class="tablepane">
            <table class="data fullwidth vouch-widget-table">
                <thead>
                    <tr>
                        <th>{{ 'Review'|t('vouch') }}</th>
                        <th class="thin">{{ 'Rating'|t('vouch') }}</th>
                        <th>{{ 'Reviewer'|t('vouch') }}</th>
                        <th>{{ 'Date'|t('vouch') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for review in reviews %}
                        <tr>
                            <td class="vouch-widget-truncate !vouch-max-w-[280px] vouch-whitespace-nowrap vouch-overflow-hidden vouch-text-ellipsis" title="{{ review.getUiLabel() }}">
                                <a href="{{ review.cpEditUrl }}" class="vouch-block vouch-overflow-hidden vouch-text-ellipsis vouch-whitespace-nowrap">{{ review.getUiLabel() }}</a>
                            </td>
                            <td>{{ review.rating }} ★</td>
                            <td class="light">{{ review.reviewerName ?: '-' }}</td>
                            <td class="light" title="{{ review.reviewedAt ? review.reviewedAt|datetime('short') : '' }}">
                                {{ review.reviewedAt ? craft.app.formatter.asRelativeTime(review.reviewedAt) : '-' }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="vouch-widget-footer vouch-mt-5 -vouch-mx-6 vouch-mb-0 vouch-pt-5 vouch-px-6 vouch-pb-0 vouch-border-t vouch-border-[color:var(--hairline-color)]">
        <a class="btn small" href="{{ indexUrl }}">{{ 'View all pending reviews'|t('vouch') }}</a>
    </div>
{% else %}
    <p>{{ 'No reviews are awaiting approval.'|t('vouch') }}</p>
{% endif %}
