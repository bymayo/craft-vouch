{# @var sources \bymayo\vouch\models\Source[] #}
{# @var providers \bymayo\vouch\connectors\ConnectorInterface[] #}
{# @var canSync bool #}
{# @var indexUrl string #}

{% if not sources|length %}
    <p class="light">{{ 'No sources configured.'|t('vouch') }} <a href="{{ indexUrl }}">{{ 'Create one'|t('vouch') }}</a></p>
{% else %}
    {% for source in sources %}
        {% set connector = providers[source.providerHandle] ?? null %}
        {% set isManual = source.providerHandle == 'manual' %}
        <div class="vouch-widget-source{% if not loop.first %} vouch-mt-3.5 vouch-pt-3.5 vouch-border-t vouch-border-[color:var(--gray-200)]{% endif %}">
            <strong class="vouch-block vouch-mb-2">{{ source.name }}{% if connector %} <span class="light vouch-font-normal">({{ connector.displayName() }})</span>{% endif %}</strong>
            <div class="vouch-flex vouch-flex-wrap vouch-gap-1.5">
                {% if canSync and not isManual %}
                    <button type="button" class="btn small vouch-sync-btn" data-source-id="{{ source.id }}" {% if not source.enabled %}disabled{% endif %}>
                        <span class="icon vouch-inline-flex vouch-w-3 vouch-h-3 vouch-mr-1 vouch-align-[-2px]">{{ iconSvg('arrows-rotate') }}</span>{{ 'Sync'|t('vouch') }}
                    </button>
                {% endif %}
                <a href="{{ cpUrl('vouch/sources/' ~ source.id) }}" class="btn small">
                    <span class="icon vouch-inline-flex vouch-w-3 vouch-h-3 vouch-mr-1 vouch-align-[-2px]">{{ iconSvg('edit') }}</span>{{ 'Edit'|t('vouch') }}
                </a>
                <a href="{{ cpUrl('vouch/reviews', { source: 'source:' ~ source.id }) }}" class="btn small">
                    <span class="icon vouch-inline-flex vouch-w-3 vouch-h-3 vouch-mr-1 vouch-align-[-2px]">{{ iconSvg('eye') }}</span>{{ 'View Reviews'|t('vouch') }}
                </a>
            </div>
            {% if not isManual %}
                <span class="light vouch-block vouch-mt-2 vouch-text-[11px]">
                    {{ 'Last Synced:'|t('vouch') }}
                    {% if source.lastSyncedAt %}
                        {{ source.lastSyncedAt|datetime('short') }}
                    {% else %}
                        {{ 'Never'|t('vouch') }}
                    {% endif %}
                </span>
            {% endif %}
        </div>
    {% endfor %}
{% endif %}

<script type="text/javascript">
(function() {
    document.querySelectorAll('.vouch-sync-btn').forEach(function(btn) {
        if (btn.dataset.vouchBound) return;
        btn.dataset.vouchBound = '1';
        btn.addEventListener('click', function() {
            var sourceId = this.getAttribute('data-source-id');
            var button = this;

            button.classList.add('loading');
            button.disabled = true;

            var body = new FormData();
            body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
            body.append('sourceId', sourceId);

            fetch(Craft.actionUrl + '/vouch/sources/sync', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: body
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                button.classList.remove('loading');
                button.disabled = false;

                if (data && data.ok) {
                    Craft.cp.displayNotice(data.message || '{{ 'Sync complete.'|t('vouch')|e('js') }}');
                } else {
                    Craft.cp.displayError((data && data.message) ? data.message : '{{ 'Sync failed.'|t('vouch')|e('js') }}');
                }
            })
            .catch(function() {
                button.classList.remove('loading');
                button.disabled = false;
                Craft.cp.displayError('{{ 'Sync failed.'|t('vouch')|e('js') }}');
            });
        });
    });
})();
</script>
