{# @var review \bymayo\vouch\elements\Review #}
{# @var manualSources \bymayo\vouch\models\Source[] #}
{# @var isManual bool #}
{# @var relatedElement \craft\base\ElementInterface|null #}
{# @var relatedElementType string #}

{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{# Existing reviews are read-only across the board - content is fixed once
   saved (synced reviews would be overwritten anyway, manual reviews stay
   immutable for audit consistency). #}
{% set isReadOnly = review.id ? true : false %}

{% set fullPageForm = true %}
{% set title = review.id ? review.getUiLabel() : 'New review'|t('vouch') %}
{% set selectedSubnavItem = 'reviews' %}

{% set crumbs = [
    { label: craft.app.plugins.getPlugin('vouch').getSettings().pluginName, url: url('vouch') },
    { label: 'Reviews'|t('vouch'), url: url('vouch/reviews') },
] %}

{% block actionButton %}
    <input type="submit" class="btn submit" value="{{ 'Save'|t('app') }}">
{% endblock %}

{% block content %}
    <input type="hidden" name="action" value="vouch/reviews/save">
    {{ redirectInput('vouch/reviews') }}
    {% if review.id %}
        <input type="hidden" name="reviewId" value="{{ review.id }}">
    {% endif %}

    {{ forms.selectField({
        first: true,
        label: 'Rating'|t('vouch'),
        id: 'rating',
        name: 'rating',
        value: (review.rating ?: 5)|round,
        options: [
            { value: 5, label: '5 ★★★★★' },
            { value: 4, label: '4 ★★★★' },
            { value: 3, label: '3 ★★★' },
            { value: 2, label: '2 ★★' },
            { value: 1, label: '1 ★' },
        ],
        required: true,
        disabled: isReadOnly,
        errors: review.getErrors('rating'),
    }) }}

    {{ forms.textField({
        label: 'Headline'|t('vouch'),
        id: 'headline',
        name: 'headline',
        value: review.headline,
        required: true,
        disabled: isReadOnly,
    }) }}

    {{ forms.textareaField({
        label: 'Review'|t('vouch'),
        id: 'review',
        name: 'review',
        value: review.review,
        rows: 5,
        required: true,
        disabled: isReadOnly,
    }) }}

    {{ forms.textField({
        label: 'Reviewer name'|t('vouch'),
        id: 'reviewerName',
        name: 'reviewerName',
        value: review.reviewerName,
        required: true,
        disabled: isReadOnly,
    }) }}

    {{ forms.textField({
        label: 'Reviewer email'|t('vouch'),
        id: 'reviewerEmail',
        name: 'reviewerEmail',
        value: review.reviewerEmail,
        type: 'email',
        required: true,
        disabled: isReadOnly,
    }) }}

    {{ forms.textareaField({
        label: 'Business reply'|t('vouch'),
        id: 'businessReply',
        name: 'businessReply',
        value: review.businessReply,
        rows: 3,
        disabled: isReadOnly,
    }) }}

    {# Related element - type dropdown drives which element-select is shown. #}
    {% set elementTypeOptions = [
        { value: 'craft\\elements\\Entry', label: 'Entry'|t('vouch') },
        { value: 'craft\\elements\\Asset', label: 'Asset'|t('vouch') },
        { value: 'craft\\elements\\Category', label: 'Category'|t('vouch') },
        { value: 'craft\\elements\\User', label: 'User'|t('vouch') },
    ] %}
    {% if craft.app.plugins.isPluginEnabled('commerce') %}
        {% set elementTypeOptions = elementTypeOptions|merge([
            { value: 'craft\\commerce\\elements\\Product', label: 'Product'|t('vouch') },
        ]) %}
    {% endif %}

    <hr>

    {{ forms.selectField({
        label: 'Related element type'|t('vouch'),
        id: 'relatedElementType',
        name: '_relatedElementType',
        value: relatedElementType,
        options: elementTypeOptions,
        disabled: isReadOnly,
    }) }}

    {% for opt in elementTypeOptions %}
        {% set isActive = opt.value == relatedElementType %}
        <div class="vouch-element-block" data-type="{{ opt.value }}"{% if not isActive %} hidden{% endif %}>
            {{ forms.elementSelectField({
                label: 'Related element'|t('vouch'),
                id: 'relatedElementId-' ~ loop.index,
                name: 'relatedElementId',
                elementType: opt.value,
                elements: (isActive and relatedElement) ? [relatedElement] : [],
                limit: 1,
                disabled: isReadOnly,
            }) }}
        </div>
    {% endfor %}

    {% if not isReadOnly %}
        {% js %}
            (function() {
                var select = document.getElementById('relatedElementType');
                if (!select) return;

                function apply(activeType) {
                    document.querySelectorAll('.vouch-element-block').forEach(function(block) {
                        var match = block.dataset.type === activeType;
                        if (match) { block.removeAttribute('hidden'); } else { block.setAttribute('hidden', ''); }
                        block.querySelectorAll('input[type="hidden"]').forEach(function(input) {
                            input.disabled = !match;
                        });
                    });
                }

                apply(select.value);
                select.addEventListener('change', function(e) { apply(e.target.value); });
            })();
        {% endjs %}
    {% endif %}

{% endblock %}

{% block details %}
    {# Right-side metadata sidebar - mirrors how Craft renders Entries,
       Categories etc. with status / dates / related entities on the right. #}
    <div id="meta-details" class="meta">
        {% if not review.id %}
            {% set sourceOptions = [] %}
            {% for s in manualSources %}
                {% set sourceOptions = sourceOptions|merge([{ value: s.id, label: s.name }]) %}
            {% endfor %}
            {{ forms.selectField({
                label: 'Source'|t('vouch'),
                id: 'sourceId',
                name: 'sourceId',
                value: review.sourceId,
                options: sourceOptions,
                required: true,
            }) }}
        {% else %}
            <div class="field">
                <div class="heading">
                    <label>{{ 'Source'|t('vouch') }}</label>
                </div>
                <div class="input">
                    {% if review.getSource() %}
                        <a href="{{ url('vouch/sources/' ~ review.getSource().id) }}">{{ review.getSource().name }}</a>
                    {% else %}
                        <span class="light">—</span>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        {{ forms.dateTimeField({
            label: 'Review Date'|t('vouch'),
            id: 'reviewedAt',
            name: 'reviewedAt',
            value: review.reviewedAt,
            required: true,
            disabled: isReadOnly,
        }) }}

        {{ forms.elementSelectField({
            label: 'Reviewer user'|t('vouch'),
            instructions: 'Auto-matched from the reviewer email. Override by selecting a different user here.'|t('vouch'),
            id: 'reviewerUserId',
            name: 'reviewerUserId',
            elementType: 'craft\\elements\\User',
            elements: review.getReviewerUser() ? [review.getReviewerUser()] : [],
            limit: 1,
            disabled: isReadOnly,
        }) }}

        {# Approved stays editable even on read-only reviews so admins can
           still flip pending reviews live without going via the bulk index. #}
        {{ forms.lightswitchField({
            label: 'Approved'|t('vouch'),
            id: 'approved',
            name: 'approved',
            on: review.approved,
        }) }}
    </div>
{% endblock %}
