{# @var plugin \bymayo\vouch\Vouch #}
{# @var sources \bymayo\vouch\models\Source[] #}
{# @var providers \bymayo\vouch\connectors\ConnectorInterface[] #}

{% extends '_layouts/cp' %}

{% set title = 'Sources'|t('vouch') %}
{% set selectedSubnavItem = 'sources' %}

{% set crumbs = [
    { label: craft.app.plugins.getPlugin('vouch').getSettings().pluginName, url: url('vouch') },
] %}

{% do view.registerAssetBundle('craft\\web\\assets\\admintable\\AdminTableAsset') %}
{% do view.registerAssetBundle('bymayo\\vouch\\web\\assets\\vouch\\VouchAsset') %}

{% block actionButton %}
    {% if providers|length and currentUser.can('vouch-createSources') %}
        <a href="{{ url('vouch/sources/new') }}" class="btn submit add icon">
            {{ 'Add source'|t('vouch') }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}

    {% if providers|length == 0 %}
        <div class="zilch">
            <p>{{ 'No provider connectors are registered yet.'|t('vouch') }}</p>
        </div>
    {% else %}
        {# Quick-add bar - one click straight to the new-source form for the
           chosen provider. Sits above the table rather than as an action
           button so all five providers are visible at once. #}
        <div class="vouch-quickadd vouch-mb-[2em]">
            <h2 class="vouch-m-0 vouch-mb-[.75em]">{{ 'Connect a new source'|t('vouch') }}</h2>
            <div class="vouch-quickadd-tiles vouch-grid vouch-gap-[.6em] vouch-grid-cols-[repeat(auto-fill,minmax(200px,1fr))]">
                {% for handle, connector in providers %}
                    <a href="{{ url('vouch/sources/new/' ~ handle) }}" class="vouch-quickadd-tile vouch-flex vouch-items-center vouch-gap-[.75em] vouch-px-[.9em] vouch-py-[.75em] vouch-border vouch-border-[#d4d4d8] vouch-rounded-md vouch-bg-white vouch-text-inherit vouch-no-underline vouch-transition-[border-color] vouch-duration-150 hover:vouch-border-[#3D7AFF] hover:vouch-no-underline">
                        {% set icon = connector.icon() %}
                        {% if icon %}
                            <span class="vouch-quickadd-icon vouch-flex-[0_0_28px] vouch-w-7 vouch-h-7 vouch-inline-flex vouch-items-center vouch-justify-center [&_svg]:vouch-w-full [&_svg]:vouch-h-full">{{ icon|raw }}</span>
                        {% endif %}
                        <span class="vouch-quickadd-label vouch-flex vouch-flex-col vouch-leading-[1.2]">
                            <span class="vouch-quickadd-name vouch-font-medium">{{ connector.displayName() }}</span>
                        </span>
                    </a>
                {% endfor %}
            </div>
        </div>

        <hr>

        <h2 class="vouch-existing-heading vouch-m-0 vouch-mb-[.75em]">{{ 'Existing sources'|t('vouch') }}</h2>

        <div id="sources-vue-admin-table"></div>
    {% endif %}

{% endblock %}

{% if providers|length %}
    {% js %}
        new Craft.VueAdminTable({
            columns: [
                { name: '__slot:title', title: Craft.t('vouch', 'Name'), sortField: false },
                { name: '__slot:handle', title: Craft.t('vouch', 'Handle'), sortField: false },
                { name: 'provider', title: Craft.t('vouch', 'Provider') },
                { name: 'connection', title: Craft.t('vouch', 'Connection'), callback: (v) => v },
                { name: 'lastSynced', title: Craft.t('vouch', 'Last synced'), callback: (v) => v },
                { name: 'sync', title: '', callback: (v) => v },
            ],
            container: '#sources-vue-admin-table',
            emptyMessage: Craft.t('vouch', 'No sources yet - pick a provider above to add one.'),
            tableDataEndpoint: 'vouch/sources/table-data',
            deleteAction: 'vouch/sources/delete',
            deleteConfirmationMessage: Craft.t('vouch', 'Are you sure you want to delete this source? Reviews already pulled in will remain.'),
            deleteSuccessMessage: Craft.t('vouch', 'Source deleted.'),
            search: true,
        });

        // VueAdminTable renders rows after the initial DOM paint, so we
        // can't kick off the connection checks from a one-shot init.
        // A MutationObserver watches the table container and fires the
        // test for any chip that hasn't been checked yet.
        (function() {
            var container = document.getElementById('sources-vue-admin-table');
            if (!container) return;

            function checkChip(chip) {
                if (!chip.dataset.pending) return;
                chip.removeAttribute('data-pending');

                var dot = chip.querySelector('.status');
                var text = chip.querySelector('.vouch-connection-text');

                var body = new FormData();
                body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                body.append('sourceId', chip.dataset.sourceId);

                function setState(klass, color, label) {
                    dot.removeAttribute('style');
                    dot.className = 'status ' + klass;
                    text.style.color = color;
                    text.textContent = label;
                }

                // Compact error label on the index - the full message is
                // shown on the source's edit page so users have somewhere
                // to read the details without flooding the table cell.
                var errLabel = '{{ 'Error'|t('vouch')|e('js') }}';

                fetch(Craft.actionUrl + '/vouch/sources/test', {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: body,
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.ok) {
                        setState('green', '#2E7D32', '{{ 'Connected'|t('vouch')|e('js') }}');
                    } else {
                        setState('red', '#C62828', errLabel);
                    }
                })
                .catch(function() {
                    setState('red', '#C62828', errLabel);
                });
            }

            function scan() {
                container.querySelectorAll('.vouch-connection-status[data-pending="1"]').forEach(checkChip);
            }

            new MutationObserver(scan).observe(container, { childList: true, subtree: true });
            scan(); // in case rows landed before the observer attached
        })();
    {% endjs %}
{% endif %}
