{# @var providers \bymayo\vouch\connectors\ConnectorInterface[] #}

{% extends '_layouts/cp' %}

{% set title = 'New source'|t('vouch') %}
{% set selectedSubnavItem = 'sources' %}

{% set crumbs = [
    { label: craft.app.plugins.getPlugin('vouch').getSettings().pluginName, url: url('vouch') },
    { label: 'Sources'|t('vouch'), url: url('vouch/sources') },
] %}

{% block content %}
    <p>{{ 'Pick a provider to connect:'|t('vouch') }}</p>

    <ul class="vouch-provider-picker">
        {% for handle, connector in providers %}
            <li>
                <a href="{{ url('vouch/sources/new/' ~ handle) }}">
                    {% set icon = connector.icon() %}
                    {% if icon %}
                        <span class="vouch-provider-icon">{{ icon|raw }}</span>
                    {% endif %}
                    <span>{{ connector.displayName() }}</span>
                </a>
            </li>
        {% endfor %}
    </ul>

    <style>
        .vouch-provider-picker { list-style:none; padding:0; margin:1em 0; display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:.75em; }
        .vouch-provider-picker a { display:flex; align-items:center; gap:.75em; padding:1em; border:1px solid #d4d4d8; border-radius:6px; text-decoration:none; color:inherit; transition: border-color .15s; }
        .vouch-provider-picker a:hover { border-color:#3D7AFF; }
        .vouch-provider-icon { display:inline-flex; width:32px; height:32px; }
        .vouch-provider-icon svg { width:100%; height:100%; }
    </style>
{% endblock %}
