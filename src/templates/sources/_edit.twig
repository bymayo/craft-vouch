{# @var source \bymayo\vouch\models\Source #}
{# @var connector \bymayo\vouch\connectors\ConnectorInterface #}
{# @var schema array #}

{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% set fullPageForm = true %}
{% set title = source.id ? source.name : 'New {provider} source'|t('vouch', { provider: connector.displayName() }) %}
{% set selectedSubnavItem = 'sources' %}

{% set crumbs = [
    { label: craft.app.plugins.getPlugin('vouch').getSettings().pluginName, url: url('vouch') },
    { label: 'Sources'|t('vouch'), url: url('vouch/sources') },
] %}

{# Wires extra options into Craft's native Save-button dropdown
   (top-right of full-page forms), matching how Entries / Categories
   render their save actions. #}
{% set formActions = [
    {
        label: 'Save and continue editing'|t('vouch'),
        redirect: 'vouch/sources/{id}'|hash,
        shortcut: true,
        retainScroll: true,
    },
] %}

{% block content %}
    <input type="hidden" name="action" value="vouch/sources/save">
    {{ redirectInput('vouch/sources') }}
    {% if source.id %}
        <input type="hidden" name="sourceId" value="{{ source.id }}">
    {% endif %}
    {# Provider handle is always submitted via this hidden input so a
       disabled-on-edit dropdown doesn't lose the value, and so JS can drive
       it from the dropdown for new sources. #}
    <input type="hidden" name="providerHandle" id="providerHandleInput" value="{{ source.providerHandle }}">

    {% set capabilities = connector.capabilities() %}
    {% if source.id and (capabilities.pull ?? false) %}
        <div class="vouch-connection-status" data-source-id="{{ source.id }}">
            <span class="status" style="background:#9CA3AF; border-color:#9CA3AF;"></span><span class="vouch-connection-text" style="font-weight:600; color:#6B7280;">{{ 'Checking…'|t('vouch') }}</span>
        </div>
        <hr>
    {% endif %}

    {{ forms.textField({
        first: true,
        label: 'Name'|t('vouch'),
        id: 'name',
        name: 'name',
        value: source.name,
        autofocus: true,
        required: true,
        errors: source.getErrors('name'),
    }) }}

    {{ forms.textField({
        label: 'Handle'|t('vouch'),
        id: 'handle',
        name: 'handle',
        class: 'code',
        value: source.handle,
        required: true,
        errors: source.getErrors('handle'),
    }) }}

    {# Auto-generate the handle from the name as the user types, until the
       handle is manually edited. Standard Craft CP behaviour, also used
       throughout the Points plugin. #}
    {% if not source.id %}
        {% js %}new Craft.HandleGenerator('#name', '#handle');{% endjs %}
    {% endif %}

    {{ forms.lightswitchField({
        label: 'Enabled'|t('vouch'),
        id: 'enabled',
        name: 'enabled',
        on: source.enabled,
    }) }}

    <hr>
    <h2>{{ 'Connection Details'|t('vouch') }}</h2>

    {% set providerOptions = [] %}
    {% for handle, p in providers %}
        {% set providerOptions = providerOptions|merge([{ value: handle, label: p.displayName() }]) %}
    {% endfor %}

    {{ forms.selectField({
        label: 'Provider'|t('vouch'),
        id: 'providerSelect',
        value: source.providerHandle,
        options: providerOptions,
        required: true,
        disabled: source.id ? true : false,
    }) }}

    {# Render every provider's schema once. JS hides non-active blocks and
       disables their inputs so only the selected provider's fields post.
       Avoids field-name collisions (e.g. `credentials[apiKey]` exists in
       Google, Trustpilot and Reviews.io). #}
    {% for handle, p in providers %}
        {% set schema = schemas[handle] %}
        {% set isActive = handle == source.providerHandle %}
        {% if schema|length %}
            <div class="vouch-schema-block" data-provider="{{ handle }}"{% if not isActive %} style="display:none;" hidden{% endif %}>
                {% for field in schema %}
                    {% set isSecret = field.secret ?? false %}
                    {% set group = isSecret ? 'credentials' : 'settings' %}
                    {% set currentValue = isActive
                        ? (isSecret ? (source.credentials[field.handle] ?? '') : (source.settings[field.handle] ?? field.default ?? ''))
                        : '' %}

                    {{ forms.autosuggestField({
                        label: field.label,
                        instructions: field.instructions ?? null,
                        id: handle ~ '-' ~ group ~ '-' ~ field.handle,
                        name: group ~ '[' ~ field.handle ~ ']',
                        value: currentValue,
                        required: field.required ?? false,
                        disabled: not isActive,
                        suggestEnvVars: true,
                        placeholder: field.placeholder ?? null,
                    }) }}
                {% endfor %}

                {% if handle == 'google' %}
                    {# Search helper - calls Places Text Search via the
                       vouch/sources/find-google-place controller action so the
                       API key never round-trips through the browser. Picking
                       a result populates the Place ID input above. #}
                    <div class="vouch-google-finder" style="margin-top:18px;padding:14px;border:1px solid var(--hairline-color);border-radius:5px;">
                        <h3 style="margin:0 0 6px 0;font-weight:600;">{{ 'Find a Place ID'|t('vouch') }}</h3>
                        <p class="light" style="margin:0 0 10px 0;">
                            {{ 'Search Google Places by name or address. Requires the API key above to be filled in.'|t('vouch') }}
                        </p>
                        <div style="display:flex;gap:8px;align-items:flex-start;">
                            <input type="text" class="text fullwidth vouch-google-finder-query"
                                   placeholder="{{ 'e.g. Spicy Vegetarian Food in Sydney, Australia'|t('vouch') }}"
                                   style="flex:1;">
                            <button type="button" class="btn submit vouch-google-finder-button">
                                {{ 'Search'|t('vouch') }}
                            </button>
                        </div>
                        <div class="vouch-google-finder-status light smalltext" style="margin-top:8px;"></div>
                        <ul class="vouch-google-finder-results" style="margin:10px 0 0 0;padding:0;list-style:none;"></ul>
                    </div>
                {% endif %}
            </div>
        {% endif %}
    {% endfor %}

    {% if not source.id %}
        {% js %}
            // Provider switcher - show/hide schema blocks and toggle their
            // inputs' disabled state so only the active provider's fields
            // make it into the POST. The hidden providerHandle input
            // mirrors the selected value.
            (function() {
                var select = document.getElementById('providerSelect');
                var hidden = document.getElementById('providerHandleInput');
                if (!select || !hidden) return;

                function activate(handle) {
                    hidden.value = handle;
                    document.querySelectorAll('.vouch-schema-block').forEach(function(block) {
                        var match = block.dataset.provider === handle;
                        block.style.display = match ? '' : 'none';
                        if (match) { block.removeAttribute('hidden'); } else { block.setAttribute('hidden', ''); }
                        block.querySelectorAll('input, textarea, select').forEach(function(input) {
                            input.disabled = !match;
                        });
                    });
                }

                select.addEventListener('change', function(e) { activate(e.target.value); });
            })();
        {% endjs %}
    {% endif %}

    {% js %}
        // Google Place ID finder - POSTs to the controller proxy with the
        // user-entered API key + query, then renders the matching places as
        // clickable rows that auto-fill the Place ID input.
        (function() {
            var block = document.querySelector('.vouch-schema-block[data-provider="google"]');
            if (!block) return;

            var btn = block.querySelector('.vouch-google-finder-button');
            var queryInput = block.querySelector('.vouch-google-finder-query');
            var statusEl = block.querySelector('.vouch-google-finder-status');
            var resultsEl = block.querySelector('.vouch-google-finder-results');
            var apiKeyInput = block.querySelector('input[name="credentials[apiKey]"]');
            var placeIdInput = block.querySelector('input[name="settings[placeId]"]');
            if (!btn || !queryInput || !apiKeyInput || !placeIdInput) return;

            function setStatus(msg, isError) {
                statusEl.textContent = msg || '';
                statusEl.style.color = isError ? 'var(--error-color, #c33)' : '';
            }

            function renderResults(places) {
                resultsEl.innerHTML = '';
                if (!places.length) {
                    setStatus({{ 'No matches found.'|t('vouch')|json_encode|raw }}, false);
                    return;
                }
                setStatus('', false);
                places.forEach(function(p) {
                    var li = document.createElement('li');
                    li.style.cssText = 'padding:8px;border:1px solid var(--hairline-color);border-radius:4px;margin-top:6px;cursor:pointer;';
                    li.innerHTML = '<strong></strong><div class="light smalltext"></div><code class="smalltext"></code>';
                    li.querySelector('strong').textContent = p.displayName || '(unnamed)';
                    li.querySelector('.light').textContent = p.address || '';
                    li.querySelector('code').textContent = p.id;
                    li.addEventListener('click', function() {
                        placeIdInput.value = p.id;
                        placeIdInput.dispatchEvent(new Event('change', { bubbles: true }));
                        setStatus({{ 'Place ID applied.'|t('vouch')|json_encode|raw }}, false);
                    });
                    resultsEl.appendChild(li);
                });
            }

            btn.addEventListener('click', function() {
                var apiKey = apiKeyInput.value.trim();
                var query = queryInput.value.trim();
                if (!apiKey) {
                    setStatus({{ 'Enter an API key above first.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }
                if (!query) {
                    setStatus({{ 'Enter a search query.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }

                btn.disabled = true;
                setStatus({{ 'Searching…'|t('vouch')|json_encode|raw }}, false);
                resultsEl.innerHTML = '';

                var data = new FormData();
                data.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                data.append('action', 'vouch/sources/find-google-place');
                data.append('apiKey', apiKey);
                data.append('query', query);

                fetch(Craft.getActionUrl('vouch/sources/find-google-place'), {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: data,
                })
                .then(function(r) { return r.json(); })
                .then(function(json) {
                    if (!json.ok) {
                        setStatus(json.message || 'Search failed.', true);
                        return;
                    }
                    renderResults(json.places || []);
                })
                .catch(function(err) {
                    setStatus(err.message || 'Search failed.', true);
                })
                .finally(function() { btn.disabled = false; });
            });

            queryInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); btn.click(); }
            });
        })();
    {% endjs %}

    <hr>
    <h2>{{ 'Moderation'|t('vouch') }}</h2>

    {{ forms.lightswitchField({
        label: 'Require manual approval'|t('vouch'),
        instructions: 'Hold reviews below {threshold} ★ for admin approval.'|t('vouch', {
            threshold: craft.app.plugins.getPlugin('vouch').getSettings().autoApproveThreshold,
        }),
        id: 'requiresApproval',
        name: 'requiresApproval',
        on: source.requiresApproval,
    }) }}

    {% if source.id and (capabilities.pull ?? false) %}
        {% js %}
            // Auto-check the connection on page load and render the result
            // as a status dot + label, matching the Akeneo settings page.
            // No button, no panel - just a chip.
            (function() {
                var container = document.querySelector('.vouch-connection-status[data-source-id]');
                if (!container) return;
                var dot = container.querySelector('.status');
                var text = container.querySelector('.vouch-connection-text');

                var body = new FormData();
                body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                body.append('sourceId', container.dataset.sourceId);

                function setState(klass, color, label) {
                    // Clear the loading-state inline styles so the .status
                    // colour class (green/red) takes over cleanly.
                    dot.removeAttribute('style');
                    dot.className = 'status ' + klass;
                    text.style.color = color;
                    text.textContent = label;
                }

                fetch(Craft.actionUrl + '/vouch/sources/test', {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: body,
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.ok) {
                        setState('green', '#2E7D32', '{{ 'Connected'|t('vouch')|e('js') }}');
                    } else {
                        setState('red', '#C62828', (data && data.message) ? data.message : '{{ 'Connection failed.'|t('vouch')|e('js') }}');
                    }
                })
                .catch(function() {
                    setState('red', '#C62828', '{{ 'Connection failed.'|t('vouch')|e('js') }}');
                });
            })();
        {% endjs %}
    {% endif %}
{% endblock %}
