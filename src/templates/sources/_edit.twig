{# @var source \bymayo\vouch\models\Source #}
{# @var connector \bymayo\vouch\connectors\ConnectorInterface #}
{# @var schema array #}

{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% set fullPageForm = true %}
{% set title = source.id ? source.name : 'New {provider} source'|t('vouch', { provider: connector.displayName() }) %}
{% set selectedSubnavItem = 'sources' %}

{% set crumbs = [
    { label: craft.app.plugins.getPlugin('vouch').getSettings().pluginName, url: url('vouch') },
    { label: 'Sources'|t('vouch'), url: url('vouch/sources') },
] %}

{# Wires extra options into Craft's native Save-button dropdown
   (top-right of full-page forms), matching how Entries / Categories
   render their save actions. #}
{% set formActions = [
    {
        label: 'Save and continue editing'|t('vouch'),
        redirect: 'vouch/sources/{id}'|hash,
        shortcut: true,
        retainScroll: true,
    },
] %}

{% block content %}
    <input type="hidden" name="action" value="vouch/sources/save">
    {{ redirectInput('vouch/sources') }}
    {% if source.id %}
        <input type="hidden" name="sourceId" value="{{ source.id }}">
    {% endif %}
    {# Provider handle is always submitted via this hidden input so a
       disabled-on-edit dropdown doesn't lose the value, and so JS can drive
       it from the dropdown for new sources. #}
    <input type="hidden" name="providerHandle" id="providerHandleInput" value="{{ source.providerHandle }}">

    {% set capabilities = connector.capabilities() %}
    {% if source.id and (capabilities.pull ?? false) %}
        <div class="vouch-connection-status" data-source-id="{{ source.id }}">
            <span class="status vouch-bg-[#9CA3AF] vouch-border-[#9CA3AF]"></span><span class="vouch-connection-text vouch-font-semibold vouch-text-[#6B7280]">{{ 'Checking…'|t('vouch') }}</span>
        </div>
        <hr>
    {% endif %}

    {{ forms.textField({
        first: true,
        label: 'Name'|t('vouch'),
        id: 'name',
        name: 'name',
        value: source.name,
        autofocus: true,
        required: true,
        errors: source.getErrors('name'),
    }) }}

    {{ forms.textField({
        label: 'Handle'|t('vouch'),
        id: 'handle',
        name: 'handle',
        class: 'code',
        value: source.handle,
        required: true,
        errors: source.getErrors('handle'),
    }) }}

    {# Auto-generate the handle from the name as the user types, until the
       handle is manually edited. Standard Craft CP behaviour, also used
       throughout the Points plugin. #}
    {% if not source.id %}
        {% js %}new Craft.HandleGenerator('#name', '#handle');{% endjs %}
    {% endif %}

    {{ forms.lightswitchField({
        label: 'Enabled'|t('vouch'),
        id: 'enabled',
        name: 'enabled',
        on: source.enabled,
    }) }}

    <hr>
    <h2>{{ 'Connection Details'|t('vouch') }}</h2>

    {% set providerOptions = [] %}
    {% for handle, p in providers %}
        {% set providerOptions = providerOptions|merge([{ value: handle, label: p.displayName() }]) %}
    {% endfor %}

    {{ forms.selectField({
        label: 'Provider'|t('vouch'),
        id: 'providerSelect',
        value: source.providerHandle,
        options: providerOptions,
        required: true,
        disabled: source.id ? true : false,
    }) }}

    {# Render every provider's schema once. JS hides non-active blocks and
       disables their inputs so only the selected provider's fields post.
       Avoids field-name collisions (e.g. `credentials[apiKey]` exists in
       Google, Trustpilot and Reviews.io). #}
    {% for handle, p in providers %}
        {% set schema = schemas[handle] %}
        {% set isActive = handle == source.providerHandle %}
        {% if schema|length %}
            <div class="vouch-schema-block" data-provider="{{ handle }}"{% if not isActive %} hidden{% endif %}>
                {% set activeMode = isActive ? (source.settings.mode ?? 'places') : 'places' %}
                {% for field in schema %}
                    {% set isSecret = field.secret ?? false %}
                    {% set group = isSecret ? 'credentials' : 'settings' %}
                    {% set currentValue = isActive
                        ? (isSecret ? (source.credentials[field.handle] ?? '') : (source.settings[field.handle] ?? field.default ?? ''))
                        : '' %}
                    {% set fieldMode = field.mode ?? null %}
                    {% set modeHidden = fieldMode and fieldMode != activeMode %}
                    {% set fieldClass = fieldMode ? 'vouch-mode-' ~ fieldMode : '' %}
                    {% set fieldId = handle ~ '-' ~ group ~ '-' ~ field.handle %}

                    {% if field.type == 'select' %}
                        {% set selectOptions = [] %}
                        {% for opt in (field.options ?? []) %}
                            {% set selectOptions = selectOptions|merge([{ value: opt.value, label: opt.label }]) %}
                        {% endfor %}
                        {{ forms.selectField({
                            label: field.label,
                            instructions: field.instructions ?? null,
                            id: fieldId,
                            name: group ~ '[' ~ field.handle ~ ']',
                            value: currentValue ?: field.default ?? '',
                            options: selectOptions,
                            disabled: not isActive,
                            class: handle == 'google' and field.handle == 'mode' ? 'vouch-google-mode' : '',
                            fieldClass: fieldClass ~ (modeHidden ? ' hidden' : ''),
                        }) }}
                    {% else %}
                        {{ forms.autosuggestField({
                            label: field.label,
                            instructions: field.instructions ?? null,
                            id: fieldId,
                            name: group ~ '[' ~ field.handle ~ ']',
                            value: currentValue,
                            required: field.required ?? false,
                            disabled: (not isActive) or (field.readOnly ?? false),
                            suggestEnvVars: true,
                            placeholder: field.placeholder ?? null,
                            fieldClass: fieldClass ~ (modeHidden ? ' hidden' : ''),
                        }) }}
                    {% endif %}
                {% endfor %}

                {% if handle == 'trustpilot' %}
                    {# Search by name/domain to find the right Business Unit ID. #}
                    <div class="vouch-trustpilot-finder vouch-mt-[18px] vouch-p-3.5 vouch-border vouch-border-[color:var(--hairline-color)] vouch-rounded-[5px]">
                        <h3 class="vouch-m-0 vouch-mb-1.5 vouch-font-semibold">{{ 'Find a Business Unit'|t('vouch') }}</h3>
                        <p class="light vouch-m-0 vouch-mb-2.5">
                            {{ 'Search Trustpilot by company name or domain. Requires the API key above to be filled in.'|t('vouch') }}
                        </p>
                        <div class="vouch-flex vouch-gap-2 vouch-items-start">
                            <input type="text" class="text fullwidth vouch-trustpilot-finder-query vouch-flex-1"
                                   placeholder="{{ 'E.g. yourdomain.com or company name…'|t('vouch') }}">
                            <button type="button" class="btn submit vouch-trustpilot-finder-button">
                                {{ 'Search'|t('vouch') }}
                            </button>
                        </div>
                        <div class="vouch-trustpilot-finder-status light smalltext vouch-mt-2"></div>
                        <ul class="vouch-trustpilot-finder-results vouch-m-0 vouch-mt-2.5 vouch-p-0 vouch-list-none"></ul>
                    </div>
                {% endif %}

                {% if handle == 'google' %}
                    {# Places-mode helper: Search by text to find the right Place ID.
                       Hidden when the Business Profile mode is active. #}
                    <div class="vouch-google-finder vouch-mode-places vouch-mt-[18px] vouch-p-3.5 vouch-border vouch-border-[color:var(--hairline-color)] vouch-rounded-[5px]{% if activeMode != 'places' %} hidden{% endif %}">
                        <h3 class="vouch-m-0 vouch-mb-1.5 vouch-font-semibold">{{ 'Find a Place ID'|t('vouch') }}</h3>
                        <p class="light vouch-m-0 vouch-mb-2.5">
                            {{ 'Search Google Places by name or address. Requires the API key above to be filled in.'|t('vouch') }}
                        </p>
                        <div class="vouch-flex vouch-gap-2 vouch-items-start">
                            <input type="text" class="text fullwidth vouch-google-finder-query vouch-flex-1"
                                   placeholder="{{ 'E.g. company name, address, zip code…'|t('vouch') }}">
                            <button type="button" class="btn submit vouch-google-finder-button">
                                {{ 'Search'|t('vouch') }}
                            </button>
                        </div>
                        <div class="vouch-google-finder-status light smalltext vouch-mt-2"></div>
                        <ul class="vouch-google-finder-results vouch-m-0 vouch-mt-2.5 vouch-p-0 vouch-list-none"></ul>
                    </div>

                    {# Business-Profile-mode helper: Connect via OAuth.
                       Requires the source to be saved first (clientId/clientSecret
                       have to live on the source row before the redirect). #}
                    <div class="vouch-google-oauth vouch-mode-businessProfile vouch-mt-[18px] vouch-p-3.5 vouch-border vouch-border-[color:var(--hairline-color)] vouch-rounded-[5px]{% if activeMode != 'businessProfile' %} hidden{% endif %}">
                        <h3 class="vouch-m-0 vouch-mb-1.5 vouch-font-semibold">{{ 'Connect Google account'|t('vouch') }}</h3>
                        {% if not source.id %}
                            <p class="light">{{ 'Save the source first (with your Client ID + Client Secret filled in), then return here to connect.'|t('vouch') }}</p>
                        {% else %}
                            {% set hasRefreshToken = (source.credentials.refreshToken ?? '') != '' %}
                            {% if hasRefreshToken %}
                                <p class="vouch-m-0 vouch-mb-2">
                                    <span class="status green"></span>
                                    {{ 'Connected.'|t('vouch') }}
                                    <a href="{{ actionUrl('vouch/sources/connect-google', { sourceId: source.id, reconnect: 1 }) }}">{{ 'Reconnect'|t('vouch') }}</a>
                                </p>
                            {% else %}
                                <p class="light vouch-m-0 vouch-mb-2.5">
                                    {{ 'Click below to authorise Vouch with your Google account. You\'ll be redirected to Google\'s consent screen.'|t('vouch') }}
                                </p>
                                <a href="{{ actionUrl('vouch/sources/connect-google', { sourceId: source.id }) }}" class="btn submit">
                                    {{ 'Connect Google account'|t('vouch') }}
                                </a>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
    {% endfor %}

    {% if not source.id %}
        {% js %}
            // Provider switcher - show/hide schema blocks and toggle their
            // inputs' disabled state so only the active provider's fields
            // make it into the POST. The hidden providerHandle input
            // mirrors the selected value.
            (function() {
                var select = document.getElementById('providerSelect');
                var hidden = document.getElementById('providerHandleInput');
                if (!select || !hidden) return;

                function activate(handle) {
                    hidden.value = handle;
                    document.querySelectorAll('.vouch-schema-block').forEach(function(block) {
                        var match = block.dataset.provider === handle;
                        block.style.display = match ? '' : 'none';
                        if (match) { block.removeAttribute('hidden'); } else { block.setAttribute('hidden', ''); }
                        block.querySelectorAll('input, textarea, select').forEach(function(input) {
                            input.disabled = !match;
                        });
                    });
                }

                select.addEventListener('change', function(e) { activate(e.target.value); });
            })();
        {% endjs %}
    {% endif %}

    {% js %}
        // Google mode switcher - shows the fields + helper block for the
        // active mode (places vs businessProfile) and hides/disables the
        // others so only the selected mode's data posts on save.
        (function() {
            var block = document.querySelector('.vouch-schema-block[data-provider="google"]');
            if (!block) return;
            var modeSelect = block.querySelector('select.vouch-google-mode')
                || block.querySelector('select[name="settings[mode]"]');
            if (!modeSelect) return;

            function applyMode(mode) {
                // Fields are emitted with `fieldClass: vouch-mode-{places|businessProfile}`
                // so each one's natural `.field` wrapper carries the toggle hook.
                // Helper panels (Finder, OAuth box) carry the same class manually.
                block.querySelectorAll('.vouch-mode-places, .vouch-mode-businessProfile').forEach(function(el) {
                    var match = el.classList.contains('vouch-mode-' + mode);
                    if (match) { el.classList.remove('hidden'); } else { el.classList.add('hidden'); }
                    el.querySelectorAll('input, textarea, select').forEach(function(input) {
                        if (input === modeSelect) return;
                        input.disabled = !match;
                    });
                });
            }

            applyMode(modeSelect.value);
            modeSelect.addEventListener('change', function(e) { applyMode(e.target.value); });
        })();
    {% endjs %}

    {% js %}
        // Google Place ID finder - POSTs to the controller proxy with the
        // user-entered API key + query, then renders the matching places as
        // clickable rows that auto-fill the Place ID input.
        (function() {
            var block = document.querySelector('.vouch-schema-block[data-provider="google"]');
            if (!block) return;

            var btn = block.querySelector('.vouch-google-finder-button');
            var queryInput = block.querySelector('.vouch-google-finder-query');
            var statusEl = block.querySelector('.vouch-google-finder-status');
            var resultsEl = block.querySelector('.vouch-google-finder-results');
            var apiKeyInput = block.querySelector('input[name="credentials[apiKey]"]');
            var placeIdInput = block.querySelector('input[name="settings[placeId]"]');
            if (!btn || !queryInput || !apiKeyInput || !placeIdInput) return;

            function setStatus(msg, isError) {
                statusEl.textContent = msg || '';
                statusEl.style.color = isError ? 'var(--error-color, #c33)' : '';
            }

            function renderResults(places) {
                resultsEl.innerHTML = '';
                if (!places.length) {
                    setStatus({{ 'No matches found.'|t('vouch')|json_encode|raw }}, false);
                    return;
                }
                setStatus('', false);
                places.forEach(function(p) {
                    var li = document.createElement('li');
                    li.className = 'vouch-p-2 vouch-border vouch-border-[color:var(--hairline-color)] vouch-rounded vouch-mt-1.5 vouch-cursor-pointer';
                    li.innerHTML = '<strong></strong><div class="light smalltext"></div><code class="smalltext"></code>';
                    li.querySelector('strong').textContent = p.displayName || '(unnamed)';
                    li.querySelector('.light').textContent = p.address || '';
                    li.querySelector('code').textContent = p.id;
                    li.addEventListener('click', function() {
                        placeIdInput.value = p.id;
                        placeIdInput.dispatchEvent(new Event('change', { bubbles: true }));
                        setStatus({{ 'Place ID applied.'|t('vouch')|json_encode|raw }}, false);
                    });
                    resultsEl.appendChild(li);
                });
            }

            btn.addEventListener('click', function() {
                var apiKey = apiKeyInput.value.trim();
                var query = queryInput.value.trim();
                if (!apiKey) {
                    setStatus({{ 'Enter an API key above first.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }
                if (!query) {
                    setStatus({{ 'Enter a search query.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }

                btn.disabled = true;
                setStatus({{ 'Searching…'|t('vouch')|json_encode|raw }}, false);
                resultsEl.innerHTML = '';

                var data = new FormData();
                data.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                data.append('action', 'vouch/sources/find-google-place');
                data.append('apiKey', apiKey);
                data.append('query', query);

                fetch(Craft.getActionUrl('vouch/sources/find-google-place'), {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: data,
                })
                .then(function(r) { return r.json(); })
                .then(function(json) {
                    if (!json.ok) {
                        setStatus(json.message || 'Search failed.', true);
                        return;
                    }
                    renderResults(json.places || []);
                })
                .catch(function(err) {
                    setStatus(err.message || 'Search failed.', true);
                })
                .finally(function() { btn.disabled = false; });
            });

            queryInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); btn.click(); }
            });
        })();
    {% endjs %}

    {% js %}
        // Trustpilot Business Unit finder - POSTs to the controller proxy
        // with the user-entered API key + query, then renders the matching
        // business units as clickable rows that auto-fill the ID input.
        (function() {
            var block = document.querySelector('.vouch-schema-block[data-provider="trustpilot"]');
            if (!block) return;

            var btn = block.querySelector('.vouch-trustpilot-finder-button');
            var queryInput = block.querySelector('.vouch-trustpilot-finder-query');
            var statusEl = block.querySelector('.vouch-trustpilot-finder-status');
            var resultsEl = block.querySelector('.vouch-trustpilot-finder-results');
            var apiKeyInput = block.querySelector('input[name="credentials[apiKey]"]');
            var businessUnitIdInput = block.querySelector('input[name="settings[businessUnitId]"]');
            if (!btn || !queryInput || !apiKeyInput || !businessUnitIdInput) return;

            function setStatus(msg, isError) {
                statusEl.textContent = msg || '';
                statusEl.style.color = isError ? 'var(--error-color, #c33)' : '';
            }

            function renderResults(units) {
                resultsEl.innerHTML = '';
                if (!units.length) {
                    setStatus({{ 'No matches found.'|t('vouch')|json_encode|raw }}, false);
                    return;
                }
                setStatus('', false);
                units.forEach(function(u) {
                    var li = document.createElement('li');
                    li.className = 'vouch-p-2 vouch-border vouch-border-[color:var(--hairline-color)] vouch-rounded vouch-mt-1.5 vouch-cursor-pointer';
                    li.innerHTML = '<strong></strong><div class="light smalltext"></div><code class="smalltext"></code>';
                    li.querySelector('strong').textContent = u.displayName || '(unnamed)';
                    li.querySelector('.light').textContent = u.websiteUrl || '';
                    li.querySelector('code').textContent = u.id;
                    li.addEventListener('click', function() {
                        businessUnitIdInput.value = u.id;
                        businessUnitIdInput.dispatchEvent(new Event('change', { bubbles: true }));
                        setStatus({{ 'Business Unit ID applied.'|t('vouch')|json_encode|raw }}, false);
                    });
                    resultsEl.appendChild(li);
                });
            }

            btn.addEventListener('click', function() {
                var apiKey = apiKeyInput.value.trim();
                var query = queryInput.value.trim();
                if (!apiKey) {
                    setStatus({{ 'Enter an API key above first.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }
                if (!query) {
                    setStatus({{ 'Enter a search query.'|t('vouch')|json_encode|raw }}, true);
                    return;
                }

                btn.disabled = true;
                setStatus({{ 'Searching…'|t('vouch')|json_encode|raw }}, false);
                resultsEl.innerHTML = '';

                var data = new FormData();
                data.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                data.append('action', 'vouch/sources/find-trustpilot-business-unit');
                data.append('apiKey', apiKey);
                data.append('query', query);

                fetch(Craft.getActionUrl('vouch/sources/find-trustpilot-business-unit'), {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: data,
                })
                .then(function(r) { return r.json(); })
                .then(function(json) {
                    if (!json.ok) {
                        setStatus(json.message || 'Search failed.', true);
                        return;
                    }
                    renderResults(json.businessUnits || []);
                })
                .catch(function(err) {
                    setStatus(err.message || 'Search failed.', true);
                })
                .finally(function() { btn.disabled = false; });
            });

            queryInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); btn.click(); }
            });
        })();
    {% endjs %}

    <hr>
    <h2>{{ 'Moderation'|t('vouch') }}</h2>

    {{ forms.lightswitchField({
        label: 'Require manual approval'|t('vouch'),
        instructions: 'Hold reviews below {threshold} ★ for admin approval.'|t('vouch', {
            threshold: craft.app.plugins.getPlugin('vouch').getSettings().autoApproveThreshold,
        }),
        id: 'requiresApproval',
        name: 'requiresApproval',
        on: source.requiresApproval,
    }) }}

    {{ forms.textField({
        label: 'Minimum rating'|t('vouch'),
        instructions: 'Drop fetched reviews below this rating before they\'re imported. Leave blank to import every rating.'|t('vouch'),
        id: 'minRating',
        name: 'minRating',
        value: source.minRating,
        type: 'number',
        size: 5,
        min: 0,
        max: 5,
        step: 0.5,
        errors: source.getErrors('minRating'),
    }) }}

    {% if source.id and (capabilities.pull ?? false) %}
        {% js %}
            // Auto-check the connection on page load and render the result
            // as a status dot + label, matching the Akeneo settings page.
            // No button, no panel - just a chip.
            (function() {
                var container = document.querySelector('.vouch-connection-status[data-source-id]');
                if (!container) return;
                var dot = container.querySelector('.status');
                var text = container.querySelector('.vouch-connection-text');

                var body = new FormData();
                body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                body.append('sourceId', container.dataset.sourceId);

                function setState(klass, color, label) {
                    // Clear the loading-state inline styles so the .status
                    // colour class (green/red) takes over cleanly.
                    dot.removeAttribute('style');
                    dot.className = 'status ' + klass;
                    text.style.color = color;
                    text.textContent = label;
                }

                fetch(Craft.actionUrl + '/vouch/sources/test', {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: body,
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.ok) {
                        setState('green', '#2E7D32', '{{ 'Connected'|t('vouch')|e('js') }}');
                    } else {
                        setState('red', '#C62828', (data && data.message) ? data.message : '{{ 'Connection failed.'|t('vouch')|e('js') }}');
                    }
                })
                .catch(function() {
                    setState('red', '#C62828', '{{ 'Connection failed.'|t('vouch')|e('js') }}');
                });
            })();
        {% endjs %}
    {% endif %}
{% endblock %}
