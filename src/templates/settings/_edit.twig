{# @var settings \bymayo\vouch\models\Settings #}

{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% set fullPageForm = true %}
{% set title = 'Settings'|t('vouch') %}
{% set selectedSubnavItem = 'settings' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('vouch') },
] %}

{% block content %}
    <input type="hidden" name="action" value="vouch/settings/save">
    {{ redirectInput('vouch/settings') }}

    {{ forms.textField({
        first: true,
        label: 'Plugin name'|t('vouch'),
        id: 'pluginName',
        name: 'settings[pluginName]',
        value: settings.pluginName,
        required: true,
        errors: settings.getErrors('pluginName'),
    }) }}

    {{ forms.lightswitchField({
        label: 'Reviewer matching'|t('vouch'),
        instructions: 'Match reviewers to Craft users by email.'|t('vouch'),
        id: 'matchAuthorsToUsers',
        name: 'settings[matchAuthorsToUsers]',
        on: settings.matchAuthorsToUsers,
    }) }}

    {{ forms.lightswitchField({
        label: 'Require login for known emails'|t('vouch'),
        instructions: 'Reject front-end submissions whose email belongs to an existing Craft user, unless the submitter is logged in as that user. Blocks email-spoofed spam reviews.'|t('vouch'),
        id: 'requireLoginForKnownEmails',
        name: 'settings[requireLoginForKnownEmails]',
        on: settings.requireLoginForKnownEmails,
    }) }}

    {{ forms.textField({
        label: 'Auto-approve threshold'|t('vouch'),
        instructions: 'Reviews at or above this rating are auto-approved.'|t('vouch'),
        id: 'autoApproveThreshold',
        name: 'settings[autoApproveThreshold]',
        value: settings.autoApproveThreshold,
        type: 'number',
        size: 5,
        errors: settings.getErrors('autoApproveThreshold'),
    }) }}

    {{ forms.textField({
        label: 'Email retention (days)'|t('vouch'),
        instructions: 'Days to keep reviewer emails before purging. 0 = never.'|t('vouch'),
        id: 'emailRetentionDays',
        name: 'settings[emailRetentionDays]',
        value: settings.emailRetentionDays,
        type: 'number',
        size: 5,
        errors: settings.getErrors('emailRetentionDays'),
    }) }}

    {{ forms.textField({
        label: 'Backfill window (days)'|t('vouch'),
        instructions: 'Days of history to pull on a source’s first sync. 0 = all.'|t('vouch'),
        id: 'backfillDays',
        name: 'settings[backfillDays]',
        value: settings.backfillDays,
        type: 'number',
        size: 5,
        errors: settings.getErrors('backfillDays'),
    }) }}

    {{ forms.textField({
        label: 'Headline max length'|t('vouch'),
        instructions: 'Maximum characters allowed for a review headline. 0 = no limit.'|t('vouch'),
        id: 'headlineMaxLength',
        name: 'settings[headlineMaxLength]',
        value: settings.headlineMaxLength,
        type: 'number',
        size: 5,
        errors: settings.getErrors('headlineMaxLength'),
    }) }}

    {{ forms.textField({
        label: 'Review max length'|t('vouch'),
        instructions: 'Maximum characters allowed for the review body. 0 = no limit.'|t('vouch'),
        id: 'reviewMaxLength',
        name: 'settings[reviewMaxLength]',
        value: settings.reviewMaxLength,
        type: 'number',
        size: 5,
        errors: settings.getErrors('reviewMaxLength'),
    }) }}

    {{ forms.textField({
        label: 'Submission rate limit'|t('vouch'),
        instructions: 'Max front-end submissions allowed per IP within the rate window. 0 = no limit.'|t('vouch'),
        id: 'submissionRateLimit',
        name: 'settings[submissionRateLimit]',
        value: settings.submissionRateLimit,
        type: 'number',
        size: 5,
        errors: settings.getErrors('submissionRateLimit'),
    }) }}

    {{ forms.textField({
        label: 'Submission rate window (seconds)'|t('vouch'),
        instructions: 'Rolling window in seconds for the rate limit above.'|t('vouch'),
        id: 'submissionRateWindow',
        name: 'settings[submissionRateWindow]',
        value: settings.submissionRateWindow,
        type: 'number',
        size: 5,
        errors: settings.getErrors('submissionRateWindow'),
    }) }}
{% endblock %}
